{
  "$schema": "https://schemas.nimblebrain.ai/v1/nimblebrain-server.schema.json",
  "name": "ai.nimblebrain/synapse-astro-editor",
  "description": "Natural-language editor for Astro websites. Chat-driven edits to text, JSX, blog posts, and image assets, with a live same-origin preview, auto-commit-per-edit on a draft branch, and one-click publish via squash-merge.",
  "version": "0.1.0",
  "title": "Astro Editor",
  "repository": {
    "url": "https://github.com/NimbleBrainInc/synapse-astro-editor",
    "source": "https://github.com/NimbleBrainInc/synapse-astro-editor"
  },
  "_meta": {
    "ai.nimblebrain/v1": {
      "runtime": "python:3.13",
      "capabilities": {
        "tools": true,
        "resources": true,
        "prompts": false
      },
      "display": {
        "category": "content",
        "tags": [
          "synapse",
          "astro",
          "website",
          "editor",
          "blog",
          "content",
          "git"
        ]
      },
      "deployment": {
        "protocol": "http",
        "port": 8000,
        "mcpPath": "/mcp"
      },
      "container": {
        "healthCheck": {
          "path": "/health",
          "port": 8000
        }
      },
      "resources": {
        "limits": {
          "memory": "1Gi",
          "cpu": "2000m"
        },
        "requests": {
          "memory": "512Mi",
          "cpu": "500m"
        }
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 1
      }
    }
  }
}
